generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  email     String?    @unique
  emailVerified Boolean @default(false)
  password  String
  createdAt DateTime   @default(now())

  workLogs  WorkLog[]
  todos     Todo[]
  notes     Note[]
  bookmarks Bookmark[]
}



model WorkLog {
  id        String   @id @default(uuid())
  content   String
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Todo {
  id        String   @id @default(uuid())
  content   String
  status    String  
  completed Boolean  @default(false) 
  tag       String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt
}


model Note {
  id        String   @id @default(uuid())
  title     String?
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bookmark {
  id          String   @id @default(uuid())
  title       String?
  url         String
  favicon     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

