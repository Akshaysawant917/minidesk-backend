generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())

  workLogs  WorkLog[]
  todos     Todo[]
  notes     Note[]
}



model WorkLog {
  id        String   @id @default(uuid())
  content   String
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Todo {
  id        String   @id @default(uuid())
  content   String
  status    String   // "TODAY" or "LATER"
  completed Boolean  @default(false) 
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}


model Note {
  id        String   @id @default(uuid())
  title     String?
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

